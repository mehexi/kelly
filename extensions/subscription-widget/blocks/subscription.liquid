{{ 'subscription-widget.css' | asset_url | stylesheet_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign current_price = current_variant.price -%}
{%- assign compare_price = current_variant.compare_at_price | default: 0 -%}
{%- assign save_pct = 0 -%}
{%- if compare_price > current_price -%}
  {%- assign save_pct = compare_price | minus: current_price | times: 100 | divided_by: compare_price -%}
{%- endif -%}

<div
  class="subscription-widget"
  data-shop="{{ shop.permanent_domain }}"
  data-app-url="{{ block.settings.app_url }}"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ current_variant.id }}"
>

  <!-- Loading -->
  <div class="subscription-widget__loading">
    <span>Loading options...</span>
  </div>

  <!-- Options -->
  <div class="subscription-widget__options" style="display:none;">

    <!-- Price header -->
    <div class="sw-price-header">
      <span class="sw-current-price">{{ current_price | money }}</span>
      {%- if compare_price > current_price -%}
        <span class="sw-compare-price">{{ compare_price | money }}</span>
        <span class="sw-save-badge">SAVE {{ save_pct }}%</span>
      {%- else -%}
        <span class="sw-compare-price" style="display:none;"></span>
        <span class="sw-save-badge" style="display:none;"></span>
      {%- endif -%}
    </div>

    <!-- Variant selector -->
    {%- if product.variants.size > 1 -%}
    <div class="sw-variant-selector">
      {%- for variant in product.variants -%}
        {%- assign v_price = variant.price -%}
        {%- assign v_compare = variant.compare_at_price | default: 0 -%}
        {%- assign v_save_amount = 0 -%}
        {%- if v_compare > v_price -%}
          {%- assign v_save_amount = v_compare | minus: v_price -%}
        {%- endif -%}
        <button
          class="sw-variant-btn{% if variant.id == current_variant.id %} active{% endif %}"
          data-variant-id="{{ variant.id }}"
          data-price="{{ v_price }}"
          data-compare-price="{{ v_compare }}"
          {%- if v_save_amount > 0 -%}
          data-savings="{{ v_save_amount | money }}"
          {%- endif -%}
        >
          <span class="sw-variant-title">{{ variant.title }}</span>
          {%- if v_save_amount > 0 -%}
            <span class="sw-variant-savings">SAVE {{ v_save_amount | money }}</span>
          {%- endif -%}
        </button>
      {%- endfor -%}
    </div>
    {%- endif -%}

    <!-- One-time row -->
    <div class="subscription-widget__row subscription-widget__row--onetime">
      <div class="sw-radio"></div>
      <div class="sw-row-text">
        <span class="sw-plan-name">ONE-TIME PURCHASE</span>
      </div>
    </div>

    <!-- Subscribe row -->
    <div class="subscription-widget__row subscription-widget__row--subscribe active">
      <div class="sw-radio"></div>
      <div class="sw-row-text">
        <span class="sw-plan-name">
          SUBSCRIBE &amp; SAVE <span class="sw-discount-label">10% OFF</span>
        </span>
        <ul class="sw-benefits">
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Recurring 10% Discount
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Swap Products Easily
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Easily Pause, Skip, or Change Frequency
          </li>
        </ul>
      </div>
    </div>

    <!-- Plan list (rendered by JS when subscribe mode is active) -->
    <div class="sw-plan-list" style="display:none;"></div>

    <!-- CTA -->
    <button class="subscription-widget__action-btn">SUBSCRIBE &amp; SAVE 🔒</button>

    <!-- Trust badges -->
    <div class="sw-trust-badges">
      <div class="sw-badge">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>60 DAY<br>GUARANTEE</span>
      </div>
      <div class="sw-badge">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>SECURE<br>CHECKOUT</span>
      </div>
    </div>

  </div><!-- /.subscription-widget__options -->

  <!-- Form -->
  <div class="subscription-widget__form" style="display:none;">
    <div class="subscription-widget__selected-plan"></div>
    <h3 class="sw-form-heading">Complete your subscription</h3>
    <div class="subscription-widget__fields">
      <div class="subscription-widget__field">
        <label>First Name</label>
        <input type="text" id="sw-first-name" placeholder="John" />
      </div>
      <div class="subscription-widget__field">
        <label>Last Name</label>
        <input type="text" id="sw-last-name" placeholder="Doe" />
      </div>
      <div class="subscription-widget__field">
        <label>Email</label>
        <input type="email" id="sw-email" placeholder="john@example.com" />
      </div>
    </div>
    <div class="subscription-widget__form-actions">
      <button class="subscription-widget__back-btn">← Back</button>
      <button class="subscription-widget__pay-btn">Subscribe Now</button>
    </div>
    <div class="subscription-widget__error" style="display:none;"></div>
  </div>

</div>

<script src="https://js.paystack.co/v2/inline.js"></script>
{{ 'subscription-widget.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Subscription Widget",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Purchase Options"
    },
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "info": "Your deployed app URL e.g. https://your-app.railway.app"
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "Active Row Color",
      "default": "#e8720c"
    }
  ]
}
{% endschema %}
