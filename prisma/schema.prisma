generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Product {
  id        String   @id @default(cuid())
  shop      String
  shopifyId String
  title     String
  handle    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plans     Plan[]

  @@unique([shop, shopifyId])
}

model Plan {
  id               String       @id @default(cuid())
  shop             String
  name             String
  description      String?
  discountPercent  Int          @default(10)  // renamed from amount, 1-99
  currency         String       @default("NGN")
  interval         String
  paystackPlanCode String?      @unique
  paystackPlanId   String?      @unique
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  productId        String?
  product          Product?     @relation(fields: [productId], references: [id])
  subscribers      Subscriber[]
}

model Subscriber {
  id                String   @id @default(cuid())
  email             String   @unique
  firstName         String?
  lastName          String?
  customerCode      String?
  authorizationCode String?
  subscriptionCode  String?
  planName          String?
  planCode          String?
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  planId            String?
  plan              Plan?    @relation(fields: [planId], references: [id])
}
