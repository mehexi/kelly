generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Product {
  id          String   @id @default(cuid())
  shop        String
  shopifyId   String   // Shopify product GID e.g. "gid://shopify/Product/123"
  title       String
  handle      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plan        Plan?    // one product -> one plan

  @@unique([shop, shopifyId])
}

model Plan {
  id               String       @id @default(cuid())
  shop             String
  name             String
  description      String?
  amount           Int
  currency         String       @default("NGN")
  interval         String       // "daily" | "weekly" | "monthly" | "biannually" | "annually"
  paystackPlanCode String?      @unique
  paystackPlanId   String?      @unique
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // link to product
  productId        String?      @unique  // one-to-one
  product          Product?     @relation(fields: [productId], references: [id])

  subscribers      Subscriber[]
}

model Subscriber {
  id                String   @id @default(cuid())
  email             String   @unique
  firstName         String?
  lastName          String?
  customerCode      String?
  authorizationCode String?
  subscriptionCode  String?
  planName          String?
  planCode          String?
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  planId            String?
  plan              Plan?    @relation(fields: [planId], references: [id])
}
